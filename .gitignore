# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.swp
*.swo
*.swn

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore all local secrets but commit the example template
.env*
!.env.local.example
.env.local
# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Generated agent artifacts
github_issues_proposals.md
pr_details.md