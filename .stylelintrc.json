{
  "extends": "stylelint-config-standard",
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "theme",
          "import",
          "custom-variant",
          "layer",
          "utility",
          "mixin",
          "define-mixin"
        ]
      }
    ],
    "no-descending-specificity": null,
    "import-notation": null,
    "selector-class-pattern": null,
    "no-empty-source": null
  }
}
